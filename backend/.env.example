# Database (required in production)
DATABASE_URL=jdbc:postgresql://localhost:5432/guideafrica?prepareThreshold=0
DATABASE_USERNAME=guideafrica
DATABASE_PASSWORD=your_secure_password

# JWT (required - no default value)
JWT_SECRET=your_jwt_secret_minimum_256_bits_long

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Mail (optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@guideafrica.com

# Upload directory
UPLOAD_DIR=./uploads
